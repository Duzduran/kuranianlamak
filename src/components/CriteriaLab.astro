---
import LocalizedText from "./LocalizedText.astro";
import { uiCopy } from "../data/i18n";
import { criteriaArchive, criteriaGroups } from "../data/criteriaArchive";

const groupMap = new Map(criteriaGroups.map((group) => [group.id, group]));

const parseCodeTokens = (code) =>
  code
    .split(".")
    .flatMap((part) =>
      Array.from(part.matchAll(/[0-9]+|[A-Za-z]+/g), (match) => {
        const value = match[0];
        return /^[0-9]+$/.test(value) ? Number(value) : value.toUpperCase();
      })
    );

const compareCodes = (left, right) => {
  const a = parseCodeTokens(left.code);
  const b = parseCodeTokens(right.code);
  const length = Math.max(a.length, b.length);

  for (let index = 0; index < length; index += 1) {
    const leftToken = a[index];
    const rightToken = b[index];

    if (leftToken === undefined) return -1;
    if (rightToken === undefined) return 1;

    if (typeof leftToken === "number" && typeof rightToken === "number") {
      if (leftToken !== rightToken) return leftToken - rightToken;
      continue;
    }

    if (typeof leftToken === "string" && typeof rightToken === "string") {
      const order = leftToken.localeCompare(rightToken, "tr");
      if (order !== 0) return order;
      continue;
    }

    if (typeof leftToken === "string") return -1;
    if (typeof rightToken === "string") return 1;
  }

  return left.code.localeCompare(right.code, "tr");
};

const uniqueMods = (entry) => [...new Set((entry.tests ?? []).flatMap((test) => test.mods))];
const discoveryLine = (entry) => {
  const tail = [entry.discovery.date, entry.discovery.place].filter(Boolean).join(" ");
  return tail ? `${entry.discovery.name} - ${tail}` : entry.discovery.name;
};
const shorten = (value, max = 160) => (value.length > max ? `${value.slice(0, max).trim()}…` : value);
const searchIndex = (entry) =>
  [
    entry.code,
    entry.title.tr,
    entry.title.en,
    entry.summary.tr,
    entry.summary.en,
    entry.discovery.name,
    entry.discovery.place ?? "",
    ...(entry.tags ?? [])
  ]
    .join(" ")
    .toLowerCase();

const groupedCriteria = criteriaGroups.map((group) => ({
  ...group,
  entries: criteriaArchive.filter((entry) => entry.groupId === group.id).sort(compareCodes)
}));

const groupCounts = groupedCriteria.map((group) => ({
  ...group,
  count: group.entries.length
}));

const totalCriteria = criteriaArchive.length;
const totalInteractive = criteriaArchive.filter((entry) => entry.tests?.length).length;
const totalResearchers = new Set(criteriaArchive.map((entry) => entry.discovery.name)).size;
const totalProtocols = criteriaArchive.reduce((total, entry) => total + (entry.tests?.length ?? 0), 0);
const previewBlocks = (entry) => {
  if (entry.tests?.length) {
    return entry.tests.slice(0, 2).map((test) => ({
      label: test.label.tr,
      value: shorten(test.sequence, 170)
    }));
  }

  if (entry.facts?.length) {
    return entry.facts.slice(0, 2).map((fact) => ({
      label: fact.label.tr,
      value: shorten(fact.value.tr, 170)
    }));
  }

  return [{ label: "Özet", value: shorten(entry.summary.tr, 170) }];
};

const resultBlocks = (entry) => {
  if (entry.tests?.length) {
    return entry.tests.slice(0, 2).map((test) => ({
      label: test.label.tr,
      value: test.mods.map((mod) => `≡ 0 (mod ${mod})`).join(" · ")
    }));
  }

  const factResult = entry.facts?.find((fact) => /sonuç|ölçüt|kriter/i.test(fact.label.tr));
  if (factResult) {
    return [{ label: factResult.label.tr, value: factResult.value.tr }];
  }

  const mods = uniqueMods(entry);
  if (mods.length) {
    return mods.map((mod) => ({ label: "Mod", value: `≡ 0 (mod ${mod})` }));
  }

  return [{ label: "Kayıt", value: "Yapısal eşitlik" }];
};

const groupToneClass = {
  alms: "tone-alms",
  hamim: "tone-hamim",
  fihrist: "tone-fihrist",
  special: "tone-special",
  "surah-ayah-19": "tone-surah-ayah-19"
};
---

<section class="lab-shell" data-archive-root>
  <header class="lab-header">
    <div class="lab-header__bar">
      <LocalizedText
        as="h1"
        class="lab-header__title"
        tr="Kur'an Yapısal Kodlamaları ve Mod 19 Bulguları"
        en="Quran structural codings and mod 19 findings"
      />
    </div>

    <div class="lab-header__meta">
      <div class="lab-header__stats">
        <span class="lab-header__stat">
          <span data-copy-lang="tr">Kriter</span>
          <strong>{totalCriteria}</strong>
        </span>
        <span class="lab-header__stat">
          <span data-copy-lang="tr">Test</span>
          <strong>{totalInteractive}</strong>
        </span>
        <span class="lab-header__stat">
          <span data-copy-lang="tr">Araştırmacı</span>
          <strong>{totalResearchers}</strong>
        </span>
        <span class="lab-header__stat">
          <span data-copy-lang="tr">Protokol</span>
          <strong>{totalProtocols}</strong>
        </span>
      </div>
    </div>
  </header>

  <div class="lab-controls">
    <div class="lab-filters" role="tablist" aria-label="Kriter grupları">
      <button type="button" class="lab-filter is-active" data-archive-filter="all">
        <span class="lab-filter__copy">
          <span data-copy-lang="tr">Tümü</span>
          <span data-copy-lang="en">All</span>
        </span>
        <strong class="lab-filter__count">{totalCriteria}</strong>
      </button>

      {
        groupCounts.map((group) => (
          <button type="button" class="lab-filter" data-archive-filter={group.id}>
            <span class="lab-filter__copy">
              <span data-copy-lang="tr">{group.title.tr}</span>
              <span data-copy-lang="en">{group.title.en}</span>
            </span>
            <strong class="lab-filter__count">{group.count}</strong>
          </button>
        ))
      }
    </div>

    <div class="lab-controls__searchline">
      <label
        class="lab-search"
        data-placeholder-tr="Kriter kodu, başlık, kişi veya etiket ara"
        data-placeholder-en="Search by code, title, person, or tag"
      >
        <span class="lab-search__label">
          <span data-copy-lang="tr">Arama</span>
          <span data-copy-lang="en">Search</span>
        </span>
        <input type="search" data-archive-search />
      </label>

      <div class="lab-toolbar__status">
        <span class="lab-toolbar__caption">
          <span data-copy-lang="tr">Gösterilen kayıt</span>
          <span data-copy-lang="en">Visible entries</span>
        </span>
        <strong class="lab-toolbar__value" data-archive-count>{totalCriteria}</strong>
      </div>
    </div>
  </div>

  <div class="lab-catalogue">
    {
      groupedCriteria.map((group) => (
        <details class="lab-section" data-group-section={group.id}>
          <summary class={`lab-section__banner ${groupToneClass[group.id] ?? ""}`}>
            <div class="lab-section__banner-copy">
              <LocalizedText as="h2" class="lab-section__title" tr={group.title.tr} en={group.title.en} />
              <LocalizedText as="p" class="lab-section__intro" tr={group.intro.tr} en={group.intro.en} />
            </div>

            <div class="lab-section__count">
              <span class="lab-section__count-copy">
                <span data-copy-lang="tr">Kayıt</span>
                <span data-copy-lang="en">Entries</span>
              </span>
              <strong data-group-visible-count>{group.entries.length}</strong>
            </div>
          </summary>

          <div class="lab-table">
            <div class="lab-table__head">
              <div class="lab-col lab-col--code">
                <span data-copy-lang="tr">No</span>
                <span data-copy-lang="en">No</span>
              </div>
              <div class="lab-col lab-col--summary">
                <span data-copy-lang="tr">Açıklama</span>
                <span data-copy-lang="en">Description</span>
              </div>
              <div class="lab-col lab-col--sequence">
                <span data-copy-lang="tr">Kodlama</span>
                <span data-copy-lang="en">Coding</span>
              </div>
              <div class="lab-col lab-col--result">
                <span data-copy-lang="tr">Ölçüt</span>
                <span data-copy-lang="en">Measure</span>
              </div>
              <div class="lab-col lab-col--detail">
                <span data-copy-lang="tr">Kayıt</span>
                <span data-copy-lang="en">Record</span>
              </div>
            </div>

            <div class="lab-table__body">
              {
                group.entries.map((entry) => {
                  const preview = previewBlocks(entry);
                  const results = resultBlocks(entry);

                  return (
                    <article
                      class="lab-table__row"
                      data-archive-card
                      data-group={entry.groupId}
                      data-search={searchIndex(entry)}
                    >
                      <div class={`lab-cell lab-cell--code ${groupToneClass[group.id] ?? ""}`}>
                        <span class="lab-cell__mobile-label">
                          <span data-copy-lang="tr">No</span>
                          <span data-copy-lang="en">No</span>
                        </span>
                        <strong>{entry.code}</strong>
                      </div>

                      <div class="lab-cell lab-cell--summary">
                        <span class="lab-cell__mobile-label">
                          <span data-copy-lang="tr">Açıklama</span>
                          <span data-copy-lang="en">Description</span>
                        </span>
                        <LocalizedText as="h3" class="lab-cell__title" tr={entry.title.tr} en={entry.title.en} />
                        <LocalizedText as="p" class="lab-cell__text" tr={entry.summary.tr} en={entry.summary.en} />
                      </div>

                      <div class="lab-cell lab-cell--sequence">
                        <span class="lab-cell__mobile-label">
                          <span data-copy-lang="tr">Kodlama</span>
                          <span data-copy-lang="en">Coding</span>
                        </span>
                        {preview.map((item) => (
                          <div class="lab-seq">
                            <strong class="lab-seq__label">{item.label}</strong>
                            <span class="lab-seq__value">{item.value}</span>
                          </div>
                        ))}
                      </div>

                      <div class="lab-cell lab-cell--result">
                        <span class="lab-cell__mobile-label">
                          <span data-copy-lang="tr">Ölçüt</span>
                          <span data-copy-lang="en">Measure</span>
                        </span>
                        {results.map((item) => (
                          <div class="lab-resultline">
                            <strong class="lab-resultline__label">{item.label}</strong>
                            <span class="lab-resultline__value">{item.value}</span>
                          </div>
                        ))}
                      </div>

                      <div class="lab-cell lab-cell--detail">
                        <span class="lab-cell__mobile-label">
                          <span data-copy-lang="tr">Kayıt</span>
                          <span data-copy-lang="en">Record</span>
                        </span>
                        <p class="lab-cell__record">{discoveryLine(entry)}</p>
                        <button type="button" class="lab-card__button" data-archive-open={entry.id}>
                          <span data-copy-lang="tr">Detay</span>
                          <span data-copy-lang="en">Detail</span>
                        </button>
                      </div>
                    </article>
                  );
                })
              }
            </div>
          </div>
        </details>
      ))
    }

    <p class="lab-empty" data-archive-empty hidden>
      <span data-copy-lang="tr">Bu filtre ve arama için eşleşen kriter bulunamadı.</span>
      <span data-copy-lang="en">No criteria matched this filter and search.</span>
    </p>
  </div>

  {
    criteriaArchive.map((entry) => {
      const tags = entry.tags ?? [];
      const group = groupMap.get(entry.groupId);

      return (
        <dialog class="lab-dialog" data-archive-dialog={entry.id}>
          <div class="lab-dialog__panel">
            <div class="lab-dialog__top">
              <div class="lab-dialog__intro">
                <div class="lab-dialog__meta">
                  <span class="lab-card__code">{`Kriter ${entry.code}`}</span>
                  <span class="lab-card__group">
                    <span data-copy-lang="tr">{group?.title.tr}</span>
                    <span data-copy-lang="en">{group?.title.en}</span>
                  </span>
                </div>
                <LocalizedText as="h2" class="lab-dialog__title" tr={entry.title.tr} en={entry.title.en} />
                <LocalizedText as="p" class="lab-dialog__text" tr={entry.summary.tr} en={entry.summary.en} />
              </div>

              <button type="button" class="lab-dialog__close" data-archive-close={entry.id}>
                <span data-copy-lang="tr">{uiCopy.tr.close}</span>
                <span data-copy-lang="en">{uiCopy.en.close}</span>
              </button>
            </div>

            <div class="lab-dialog__columns">
              <section class="lab-overview">
                {entry.facts?.length ? (
                  <div class="lab-overview__facts">
                    {entry.facts.map((fact) => (
                      <article class="lab-overview__fact">
                        <LocalizedText as="h3" class="lab-overview__label" tr={fact.label.tr} en={fact.label.en} />
                        <LocalizedText as="p" class="lab-overview__value" tr={fact.value.tr} en={fact.value.en} />
                      </article>
                    ))}
                  </div>
                ) : null}

                {tags.length ? (
                  <div class="lab-overview__tags">
                    {tags.map((tag) => (
                      <span class="lab-tag">{tag}</span>
                    ))}
                  </div>
                ) : null}

                <div class="lab-source">
                  <div class="lab-source__row">
                    <span class="lab-source__label">
                      <span data-copy-lang="tr">Keşif kaydı</span>
                      <span data-copy-lang="en">Discovery record</span>
                    </span>
                    <span class="lab-source__value">{discoveryLine(entry)}</span>
                  </div>
                  {entry.sourceUrl && entry.sourceLabel ? (
                    <div class="lab-source__row">
                      <span class="lab-source__label">
                        <span data-copy-lang="tr">Kaynak sayfa</span>
                        <span data-copy-lang="en">Source page</span>
                      </span>
                      <a class="lab-source__link" href={entry.sourceUrl} target="_blank" rel="noreferrer">
                        <span data-copy-lang="tr">{entry.sourceLabel.tr}</span>
                        <span data-copy-lang="en">{entry.sourceLabel.en}</span>
                      </a>
                    </div>
                  ) : null}
                </div>
              </section>

              <section class="lab-workbench">
                {entry.tests?.length ? (
                  <>
                    <LocalizedText
                      as="p"
                      class="lab-workbench__intro"
                      tr="Aşağıdaki alanlarda boşluklar ve noktalama yok sayılır; sadece rakamlar mod hesabına katılır."
                      en="Spaces and punctuation are ignored below; only digits are included in the modular calculation."
                    />

                    {entry.tests.map((test) => (
                      <article class="lab-test" data-mod-tester data-mods={test.mods.join(",")}>
                        <div class="lab-test__head">
                          <LocalizedText as="h3" class="lab-test__title" tr={test.label.tr} en={test.label.en} />
                          <div class="lab-badges">
                            {test.mods.map((mod) => (
                              <span class="lab-badge">{`mod ${mod}`}</span>
                            ))}
                          </div>
                        </div>

                        {test.note ? <LocalizedText as="p" class="lab-test__note" tr={test.note.tr} en={test.note.en} /> : null}

                        <textarea class="lab-test__textarea" data-mod-input data-default-sequence={test.sequence}>{test.sequence}</textarea>

                        <div class="lab-test__actions">
                          <button type="button" class="lab-test__action" data-mod-analyze>
                            <span data-copy-lang="tr">{uiCopy.tr.analyze}</span>
                            <span data-copy-lang="en">{uiCopy.en.analyze}</span>
                          </button>
                          <button type="button" class="lab-test__action lab-test__action--muted" data-mod-reset>
                            <span data-copy-lang="tr">{uiCopy.tr.reset}</span>
                            <span data-copy-lang="en">{uiCopy.en.reset}</span>
                          </button>
                        </div>

                        <div class="lab-test__results">
                          <p class="lab-result">
                            <span class="lab-result__label">
                              <span data-copy-lang="tr">Basamak sayısı</span>
                              <span data-copy-lang="en">Digit count</span>
                            </span>
                            <strong class="lab-result__value" data-result-digits>0</strong>
                          </p>

                          {test.mods.map((mod) => (
                            <p class="lab-result" data-mod-row={mod}>
                              <span class="lab-result__label">{`mod ${mod}`}</span>
                              <strong class="lab-result__value" data-result-mod={mod}>
                                0
                              </strong>
                            </p>
                          ))}
                        </div>
                      </article>
                    ))}
                  </>
                ) : (
                  <div class="lab-workbench__empty">
                    <LocalizedText
                      as="p"
                      class="lab-workbench__intro"
                      tr="Bu kartta doğrudan mod testi yerine eşitlik, simetri ya da özet bir yapısal kayıt öne çıkıyor."
                      en="This card emphasizes an equality, symmetry, or structural summary rather than a direct modular test."
                    />
                  </div>
                )}
              </section>
            </div>
          </div>
        </dialog>
      );
    })
  }
</section>

<script>
  const archiveRoot = document.querySelector("[data-archive-root]");

  if (archiveRoot instanceof HTMLElement) {
    const localeAwarePlaceholder = () => {
      const search = archiveRoot.querySelector("[data-archive-search]");
      if (!(search instanceof HTMLInputElement)) return;

      const locale = document.documentElement.dataset.locale === "en" ? "en" : "tr";
      search.placeholder =
        locale === "en" ? search.parentElement?.getAttribute("data-placeholder-en") ?? "" : search.parentElement?.getAttribute("data-placeholder-tr") ?? "";
    };

    localeAwarePlaceholder();
    window.addEventListener("site:locale-change", localeAwarePlaceholder);

    const groupSections = Array.from(archiveRoot.querySelectorAll("[data-group-section]"));
    const filterButtons = Array.from(archiveRoot.querySelectorAll("[data-archive-filter]"));
    const searchInput = archiveRoot.querySelector("[data-archive-search]");
    const emptyState = archiveRoot.querySelector("[data-archive-empty]");
    const countTarget = archiveRoot.querySelector("[data-archive-count]");
    let activeFilter = "all";

    const updateArchiveCards = () => {
      const query =
        searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";

      let visibleCount = 0;

      groupSections.forEach((section) => {
        if (!(section instanceof HTMLElement)) return;

        const sectionId = section.dataset.groupSection ?? "";
        const sectionCards = Array.from(section.querySelectorAll("[data-archive-card]"));
        let sectionVisibleCount = 0;

        sectionCards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const matchesFilter = activeFilter === "all" || card.dataset.group === activeFilter;
          const matchesSearch = !query || (card.dataset.search ?? "").includes(query);
          const visible = matchesFilter && matchesSearch;
          card.hidden = !visible;
          if (visible) {
            visibleCount += 1;
            sectionVisibleCount += 1;
          }
        });

        const hideSection = sectionVisibleCount === 0 || (activeFilter !== "all" && sectionId !== activeFilter);
        section.hidden = hideSection;

        if (!hideSection && section instanceof HTMLDetailsElement && (activeFilter !== "all" || query)) {
          section.open = true;
        }

        const sectionCountTarget = section.querySelector("[data-group-visible-count]");
        if (sectionCountTarget instanceof HTMLElement) {
          sectionCountTarget.textContent = String(sectionVisibleCount);
        }
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = visibleCount > 0;
      }

      if (countTarget instanceof HTMLElement) {
        countTarget.textContent = String(visibleCount);
      }
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLButtonElement)) return;
        activeFilter = button.dataset.archiveFilter ?? "all";

        filterButtons.forEach((candidate) => {
          if (!(candidate instanceof HTMLButtonElement)) return;
          candidate.classList.toggle("is-active", candidate === button);
        });

        updateArchiveCards();
      });
    });

    searchInput?.addEventListener("input", updateArchiveCards);
    updateArchiveCards();

    const openButtons = Array.from(archiveRoot.querySelectorAll("[data-archive-open]"));
    const closeButtons = Array.from(archiveRoot.querySelectorAll("[data-archive-close]"));
    const dialogs = Array.from(archiveRoot.querySelectorAll("[data-archive-dialog]"));

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.getAttribute("data-archive-open");
        const dialog = archiveRoot.querySelector(`[data-archive-dialog="${id}"]`);
        if (dialog instanceof HTMLDialogElement) {
          dialog.showModal();
        }
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.getAttribute("data-archive-close");
        const dialog = archiveRoot.querySelector(`[data-archive-dialog="${id}"]`);
        if (dialog instanceof HTMLDialogElement) {
          dialog.close();
        }
      });
    });

    dialogs.forEach((dialog) => {
      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          dialog.close();
        }
      });
    });

    const computeMod = (value, mod) => {
      let remainder = 0;
      let digits = 0;

      for (const character of value) {
        const code = character.charCodeAt(0);
        if (code < 48 || code > 57) continue;
        remainder = (remainder * 10 + (code - 48)) % mod;
        digits += 1;
      }

      return { remainder, digits };
    };

    const testers = Array.from(archiveRoot.querySelectorAll("[data-mod-tester]"));

    testers.forEach((tester) => {
      if (!(tester instanceof HTMLElement)) return;

      const input = tester.querySelector("[data-mod-input]");
      const analyzeButton = tester.querySelector("[data-mod-analyze]");
      const resetButton = tester.querySelector("[data-mod-reset]");
      const digitsTarget = tester.querySelector("[data-result-digits]");
      const mods = (tester.dataset.mods ?? "")
        .split(",")
        .map((value) => Number(value))
        .filter((value) => Number.isFinite(value));

      const render = () => {
        if (!(input instanceof HTMLTextAreaElement)) return;

        let digitCount = 0;

        mods.forEach((mod) => {
          const result = computeMod(input.value, mod);
          digitCount = result.digits;
          const valueTarget = tester.querySelector(`[data-result-mod="${mod}"]`);
          const rowTarget = tester.querySelector(`[data-mod-row="${mod}"]`);

          if (valueTarget instanceof HTMLElement) {
            valueTarget.textContent = String(result.remainder);
          }

          if (rowTarget instanceof HTMLElement) {
            rowTarget.dataset.pass = String(result.remainder === 0);
          }
        });

        if (digitsTarget instanceof HTMLElement) {
          digitsTarget.textContent = String(digitCount);
        }
      };

      analyzeButton?.addEventListener("click", render);

      resetButton?.addEventListener("click", () => {
        if (input instanceof HTMLTextAreaElement) {
          input.value = input.dataset.defaultSequence ?? "";
          render();
        }
      });

      input?.addEventListener("input", render);
      render();
    });
  }
</script>

<style>
  .lab-shell {
    --lab-text: var(--theme-ink);
    --lab-heading: var(--theme-ink-strong);
    --lab-body: var(--theme-ink-soft);
    --lab-muted: var(--theme-muted);
    --lab-muted-soft: var(--theme-muted-soft);
    --lab-border: var(--theme-border-strong);
    --lab-border-soft: var(--theme-border);
    --lab-surface: var(--theme-surface);
    --lab-surface-soft: var(--theme-surface-soft);
    --lab-surface-muted: var(--theme-surface-muted);
    --lab-header: var(--theme-header);
    --lab-link: var(--theme-link);
    --lab-success: var(--theme-success);
    --lab-pass-bg: var(--theme-success-soft);
    --lab-pass-border: #2b8b2b;
    --lab-fail-bg: var(--theme-fail-soft);
    --lab-fail-border: #b66a54;
    --lab-overlay: var(--theme-overlay);
    --lab-dialog-shadow: 0 14px 32px rgba(18, 26, 36, 0.14);
    display: grid;
    gap: 1rem;
    color: var(--lab-text);
  }

  html[data-theme="dark"] .lab-shell {
