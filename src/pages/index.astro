---
import Layout from "../layouts/Layout.astro";
import LocalizedText from "../components/LocalizedText.astro";

const l = (tr, en = tr) => ({ tr, en });

const areas = [
  {
    href: "/kurani-anlamak",
    title: l("Kur'an'ı Anlamak", "Understanding the Qur'an"),
    text: l(
      "Metne giriş, anlatı akışı ve temel okuma eşikleri.",
      "Textual entry, narrative flow, and the primary reading thresholds."
    )
  },
  {
    href: "/kriter-arsivi",
    title: l("Kriter Arşivi", "Criteria Archive"),
    text: l(
      "Fihrist bulguları, Ha-Mim bağlantıları ve mod 19 kümeleri.",
      "Index findings, Ha-Mim links, and mod 19 clusters."
    )
  },
  {
    href: "/forum",
    title: l("Forum", "Forum"),
    text: l(
      "Forum, ortak notlar ve ileride açılacak topluluk alanı.",
      "Forum, shared notes, and the community area that will open later."
    )
  }
];
---

<Layout
  title="Within19"
  description="Within19 ana giriş sayfası. Kur'an'ı Anlamak, Kriter Arşivi ve Forum alanlarına sade bir ana yüzeyden erişim."
>
  <section class="entry">
    <header class="entry__topbar">
      <a class="entry__brand" href="/">WITHIN19</a>

      <nav class="entry__nav" aria-label="Primary">
        <a href="/kurani-anlamak">
          <span data-copy-lang="tr">Kur'an'ı Anlamak</span>
          <span data-copy-lang="en">Understanding</span>
        </a>
        <a href="/kriter-arsivi">
          <span data-copy-lang="tr">Kriter Arşivi</span>
          <span data-copy-lang="en">Archive</span>
        </a>
        <a href="/forum">
          <span data-copy-lang="tr">Forum</span>
          <span data-copy-lang="en">Forum</span>
        </a>
      </nav>
    </header>

    <section class="entry__hero">
      <figure class="entry__verse">
        <LocalizedText
          as="blockquote"
          class="entry__quote"
          tr="Hep birlikte Allah'ın ipine sımsıkı tutunun ve ayrılığa düşmeyin."
          en="Hold fast, all together, to the rope of Allah, and do not be divided."
        />
        <figcaption class="entry__reference">Ali 'Imran 3:103</figcaption>
      </figure>
    </section>

    <section class="entry__areas" aria-label="Primary areas">
      {
        areas.map((area, index) => (
          <a class="entry__area" href={area.href}>
            <span class="entry__area-index">{String(index + 1).padStart(2, "0")}</span>
            <div class="entry__area-body">
              <LocalizedText as="h2" class="entry__area-title" tr={area.title.tr} en={area.title.en} />
              <LocalizedText as="p" class="entry__area-text" tr={area.text.tr} en={area.text.en} />
            </div>
            <span class="entry__area-arrow" aria-hidden="true">↗</span>
          </a>
        ))
      }
    </section>
  </section>
</Layout>

<style>
  .entry {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4.5rem;
    color: var(--theme-ink);
  }

  .entry__topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .entry__brand {
    color: var(--theme-ink-strong);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .entry__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
  }

  .entry__nav a {
    color: var(--theme-muted);
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
  }

  .entry__nav a:hover {
    color: var(--theme-ink-strong);
  }

  .entry__hero {
    padding: 6rem 0 4.5rem;
  }

  .entry__area-title {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--theme-ink-strong);
  }

  .entry__verse {
    margin: 0 auto;
    max-width: 54rem;
    text-align: center;
  }

  .entry__quote {
    margin: 0;
    color: var(--theme-ink-soft);
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 4vw, 3.9rem);
    line-height: 1.22;
    text-wrap: balance;
  }

  .entry__reference {
    margin-top: 0.7rem;
    color: var(--theme-muted);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .entry__areas {
    display: grid;
  }

  .entry__area {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr) 2rem;
    gap: 1rem;
    padding: 1.55rem 0;
    border-top: 1px solid var(--theme-border);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .entry__area:last-child {
    border-bottom: 1px solid var(--theme-border);
  }

  .entry__area:hover,
  .entry__area:focus-visible {
    border-color: var(--theme-border-strong);
    transform: translateX(2px);
    outline: none;
  }

  .entry__area-index {
    color: var(--theme-muted-soft);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .entry__area-body {
    max-width: 44rem;
  }

  .entry__area-title {
    font-size: clamp(1.28rem, 1.8vw, 1.72rem);
    line-height: 1.2;
    transition: color 160ms ease;
  }

  .entry__area-text {
    margin: 0.55rem 0 0;
    color: var(--theme-ink-soft);
    font-size: 0.98rem;
    line-height: 1.72;
  }

  .entry__area-arrow {
    align-self: center;
    justify-self: end;
    color: var(--theme-muted-soft);
    font-size: 1.1rem;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .entry__area:hover .entry__area-title,
  .entry__area:focus-visible .entry__area-title {
    color: var(--theme-link);
  }

  .entry__area:hover .entry__area-arrow,
  .entry__area:focus-visible .entry__area-arrow {
    color: var(--theme-link);
    transform: translate(2px, -2px);
  }

  @media (max-width: 760px) {
    .entry {
      width: min(100vw - 1rem, 100%);
      padding-bottom: 3.5rem;
    }

    .entry__topbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }

    .entry__hero {
      padding: 4.8rem 0 3.6rem;
    }

    .entry__area {
      grid-template-columns: 1fr auto;
      gap: 0.55rem;
      padding: 1.2rem 0;
    }

    .entry__area-index,
    .entry__area-arrow {
      grid-row: 1;
    }

    .entry__area-body {
      grid-column: 1 / -1;
    }

    .entry__area-text {
      font-size: 0.93rem;
      line-height: 1.64;
    }

    .entry__quote {
      font-size: clamp(1.45rem, 8vw, 2.4rem);
      line-height: 1.28;
    }
  }
</style>
