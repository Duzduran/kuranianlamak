<script
  define:vars={{
    allah15124Preview,
    analyzerMessages: {
      tr: {
        ready: "15124 basamaklı sayı hazır.",
        empty: "Önce sayıyı gir.",
        mutated: "Bir rakam değiştirildi. Şimdi tekrar analiz edebilirsin.",
        updated: "Sayı güncellendi.",
        restored: "15124 basamaklı sayı geri yüklendi."
      },
      en: {
        ready: "The 15124-digit number is ready.",
        empty: "Enter the number first.",
        mutated: "One digit was changed. You can analyze it again now.",
        updated: "The number was updated.",
        restored: "The 15124-digit number was restored."
      }
    }
  }}
>
  document.documentElement.classList.add("has-reveal");

  const dialog = document.querySelector("[data-15124-dialog]");
  const openButton = document.querySelector("[data-15124-open]");
  const closeButton = document.querySelector("[data-15124-close]");
  const fatihaDialog = document.querySelector("[data-fatiha-dialog]");
  const fatihaOpenButton = document.querySelector("[data-fatiha-open]");
  const fatihaCloseButton = document.querySelector("[data-fatiha-close]");
  const detailDialogs = Array.from(document.querySelectorAll("[data-detail-dialog]"));
  const detailOpenButtons = Array.from(document.querySelectorAll("[data-detail-open]"));
  const detailCloseButtons = Array.from(document.querySelectorAll("[data-detail-close]"));
  const criteriaDialogs = Array.from(document.querySelectorAll("[data-criteria-dialog]"));
  const criteriaOpenButtons = Array.from(document.querySelectorAll("[data-criteria-open]"));
  const criteriaCloseButtons = Array.from(document.querySelectorAll("[data-criteria-close]"));
  const input = document.querySelector("[data-15124-input]");
  const analyzeButton = document.querySelector("[data-15124-analyze]");
  const mutateButton = document.querySelector("[data-15124-mutate]");
  const resetButton = document.querySelector("[data-15124-reset]");
  const status = document.querySelector("[data-15124-status]");
  const revealItems = Array.from(document.querySelectorAll("[data-reveal]"));
  let statusState = { type: "ready" };

  const getLocale = () => (document.documentElement.dataset.locale === "en" ? "en" : "tr");

  if (revealItems.length && "IntersectionObserver" in window) {
    const revealObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.18,
        rootMargin: "0px 0px -10% 0px"
      }
    );

    revealItems.forEach((item, index) => {
      if (index === 0) {
        item.classList.add("is-visible");
      }

      revealObserver.observe(item);
    });
  } else {
    revealItems.forEach((item) => item.classList.add("is-visible"));
  }

  const computeMod19 = (value) => {
    let mod = 0;
    let length = 0;

    for (const char of value) {
      if (char < "0" || char > "9") continue;
      mod = (mod * 10 + Number(char)) % 19;
      length += 1;
    }

    return { mod, length };
  };

  const setStatus = (message, tone, state) => {
    if (!status) return;
    status.textContent = message;
    status.dataset.tone = tone;
    statusState = state;
  };

  const renderStatus = () => {
    const locale = getLocale();
    const messages = analyzerMessages[locale];

    if (statusState.type === "empty") {
      setStatus(messages.empty, "idle", statusState);
      return;
    }

    if (statusState.type === "mutated") {
      setStatus(messages.mutated, "idle", statusState);
      return;
    }

    if (statusState.type === "updated") {
      setStatus(messages.updated, "idle", statusState);
      return;
    }

    if (statusState.type === "restored") {
      setStatus(messages.restored, "idle", statusState);
      return;
    }

    if (statusState.type === "result") {
      const tone = statusState.mod === 0 ? "success" : "fail";
      const message =
        locale === "tr"
          ? statusState.mod === 0
            ? `${statusState.length} basamaklı sayı mod 19 = 0 veriyor.`
            : `${statusState.length} basamaklı sayı mod 19 = ${statusState.mod} veriyor.`
          : statusState.mod === 0
            ? `The ${statusState.length}-digit number gives mod 19 = 0.`
            : `The ${statusState.length}-digit number gives mod 19 = ${statusState.mod}.`;
      setStatus(message, tone, statusState);
      return;
    }

    setStatus(messages.ready, "idle", { type: "ready" });
  };

  openButton?.addEventListener("click", () => {
    dialog?.showModal();
  });

  closeButton?.addEventListener("click", () => {
    dialog?.close();
  });

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

  fatihaOpenButton?.addEventListener("click", () => {
    fatihaDialog?.showModal();
  });

  fatihaCloseButton?.addEventListener("click", () => {
    fatihaDialog?.close();
  });

  fatihaDialog?.addEventListener("click", (event) => {
    if (event.target === fatihaDialog) {
      fatihaDialog.close();
    }
  });

  detailOpenButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-detail-open");
      const target = document.querySelector(`[data-detail-dialog="${id}"]`);
      target?.showModal();
    });
  });

  detailCloseButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-detail-close");
      const target = document.querySelector(`[data-detail-dialog="${id}"]`);
      target?.close();
    });
  });

  detailDialogs.forEach((detailDialog) => {
    detailDialog.addEventListener("click", (event) => {
      if (event.target === detailDialog) {
        detailDialog.close();
      }
    });
  });

  criteriaOpenButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-criteria-open");
      const target = document.querySelector(`[data-criteria-dialog="${id}"]`);
      target?.showModal();
    });
  });

  criteriaCloseButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-criteria-close");
      const target = document.querySelector(`[data-criteria-dialog="${id}"]`);
      target?.close();
    });
  });

  criteriaDialogs.forEach((criteriaDialog) => {
    criteriaDialog.addEventListener("click", (event) => {
      if (event.target === criteriaDialog) {
        criteriaDialog.close();
      }
    });
  });

  analyzeButton?.addEventListener("click", () => {
    if (!input) return;
    const { mod, length } = computeMod19(input.value);

    if (!length) {
      statusState = { type: "empty" };
      renderStatus();
      return;
    }

    statusState = { type: "result", length, mod };
    renderStatus();
  });

  mutateButton?.addEventListener("click", () => {
    if (!input) return;
    const chars = Array.from(input.value);
    const index = chars.findIndex((char) => char >= "0" && char <= "8");

    if (index === -1) return;

    chars[index] = String(Number(chars[index]) + 1);
    input.value = chars.join("");
    statusState = { type: "mutated" };
    renderStatus();
  });

  input?.addEventListener("input", () => {
    statusState = { type: "updated" };
    renderStatus();
  });

  resetButton?.addEventListener("click", () => {
    if (!input) return;
    input.value = allah15124Preview;
    statusState = { type: "restored" };
    renderStatus();
  });

  if (input) {
    input.value = allah15124Preview;
  }

  renderStatus();
  window.addEventListener("site:locale-change", renderStatus);
</script>
