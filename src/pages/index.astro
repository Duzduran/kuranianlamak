---
import Layout from "../layouts/Layout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import ScrollCue from "../components/ScrollCue.astro";
import HeroRive from "../components/HeroRive.astro";
import { allah15124Number } from "../data/allah15124";
import { uiCopy } from "../data/i18n";

const l = (tr, en) => ({ tr, en });

const besmeleCriteriaGroups = [
  {
    id: "temel",
    range: "B1-B2",
    title: l("Temel ölçüler", "Core measures"),
    intro: l("İlk bakışta görünen ana ölçüler burada toplanır.", "The main measures visible at first glance gather here."),
    items: [
      ["B1", l("Harf sayısı", "Letter count"), "19", l("mod 19 = 0", "mod 19 = 0")],
      ["B2", l("Kelime, harf ve ebced dizilimi", "Word, letter, and abjad sequence"), "4 19 786", l("mod 19 = 0", "mod 19 = 0")]
    ]
  },
  {
    id: "harf",
    range: "B3-B4",
    title: l("Harf dizilimleri", "Letter sequences"),
    intro: l("Kelime sırası ve harf düzeni birlikte okunur.", "Word order and letter structure are read together."),
    items: [
      [
        "B3",
        l("Kelime sırası ve harf sayıları", "Word order and letter counts"),
        l("1 3 / 2 4 / 3 6 / 4 6 ve tersi", "1 3 / 2 4 / 3 6 / 4 6 and its reverse"),
        l("iki yönde mod 19 = 0", "mod 19 = 0 in both directions")
      ],
      [
        "B4",
        l("Kelime numarası ve kümülatif harf toplamları", "Word number and cumulative letter totals"),
        "1 3 / 2 7 / 3 13 / 4 19",
        l("mod 19 = 0", "mod 19 = 0")
      ]
    ]
  },
  {
    id: "ebced",
    range: "B5-B6.1",
    title: l("Ebced dizilimleri", "Abjad sequences"),
    intro: l("Ebced değerleri tek tek ve kümülatif biçimde izlenir.", "Abjad values are traced one by one and cumulatively."),
    items: [
      ["B5", l("Kelime sırası ve ebced değerleri", "Word order and abjad values"), "1 102 / 2 66 / 3 329 / 4 289", l("mod 19 = 0", "mod 19 = 0")],
      ["B6", l("Kelime numarası ve kümülatif ebced toplamları", "Word number and cumulative abjad totals"), "1 102 / 2 168 / 3 497 / 4 786", l("mod 19 = 0", "mod 19 = 0")],
      ["B6.1", l("Asal çarpan toplamları dizilimi", "Prime factor sum sequence"), "0 22 2 16 3 78 4 136", l("mod 19 = 0", "mod 19 = 0")]
    ]
  },
  {
    id: "ileri",
    range: "B7-B9",
    title: l("İleri ölçütler", "Advanced measures"),
    intro: l("Daha yoğun dizilimler ve birleşik yapılar bu katmanda yer alır.", "Denser sequences and composite structures appear in this layer."),
    items: [
      [
        "B7",
        l("Kelime ve harf ebced dizilimi", "Word and letter abjad sequence"),
        l("Düz, ters, basamak toplamı ve kayan pencere", "Forward, reverse, digit sum, and sliding window"),
        l("hepsi mod 19 = 0", "all give mod 19 = 0")
      ],
      ["B8", l("Harf ebcedlerinin kümülatif dizilimi", "Cumulative sequence of letter abjads"), "1 2 62 102 ... 4 786", l("mod 19 = 0", "mod 19 = 0")],
      [
        "B9",
        l("Kelime sıra no, harf sıra no ve harf ebced dizilimi", "Word no, letter no, and letter abjad sequence"),
        "1 1 2 2 60 ... 4 1 30 200 8 10 40",
        l("mod 19 = 0", "mod 19 = 0")
      ]
    ]
  }
];

const escapeHtml = (value) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;");

const highlightNumericText = (value) =>
  escapeHtml(value).replace(/(\d+(?:\.\d+)?|mod|x|=)/g, '<span class="criteria-number">$1</span>');

const allah15124Preview = allah15124Number.match(/.{1,88}/g)?.join("\n") ?? allah15124Number;

const allah15124Fields = [
  [l("Kuran ayet no", "Qur'an ayah no"), "number-field--quran-ayah"],
  [l("Sure no", "Surah no"), "number-field--surah"],
  [l("Suredeki ayet no", "Ayah no in the surah"), "number-field--surah-ayah"],
  [l("Geçiş sayısı", "Occurrence count"), "number-field--count"]
];

const allah15124Sequence = [
  ["1", "1", "1", "1"],
  ["2", "1", "2", "1"],
  ["14", "2", "7", "1"],
  ["6221", "112", "2", "1"]
];

const allahWordBreakdown = [
  [l("İsim", "Name"), l("19 = 19 x 1", "19 = 19 x 1")],
  [l("Allah ve türevleri", "Allah and its derivatives"), l("2698 = 19 x 142", "2698 = 19 x 142")],
  [l("Rahman", "Al-Rahman"), l("57 = 19 x 3", "57 = 19 x 3")],
  [l("Rahim", "Al-Rahim"), l("114 = 19 x 6", "114 = 19 x 6")],
  [
    l("Ayet no'su 19'un katı olan ayetlerde Allah", "In verses whose verse number is a multiple of 19"),
    l("Allah kelimesi 133 kez geçer. 133, 19'un katıdır.", "The word Allah appears 133 times. 133 is a multiple of 19.")
  ],
  [l("Allah + er-Rahman + er-Rahim", "Allah + Al-Rahman + Al-Rahim"), l("684 = 19 x 36", "684 = 19 x 36")]
];
---

<Layout>
  <section class="home-hero">
    <div class="mx-auto max-w-4xl px-5 py-18 text-center md:px-8 md:py-28">
      <LocalizedText
        as="h1"
        class="mx-auto mt-6 max-w-4xl font-serif text-4xl leading-[1.08] text-balance text-[var(--c-ink)] md:text-7xl"
        tr="Kur'an'ı anlamak."
        en="Understanding the Qur'an."
      />
      <figure class="mx-auto mt-7 max-w-xl">
        <LocalizedText
          as="blockquote"
          class="font-serif text-xl leading-9 text-[var(--c-ink-soft)] md:text-2xl md:leading-10"
          tr="“Rabbim, ilmimi artır.”"
          en="“My Rabb, increase me in knowledge.”"
        />
        <figcaption class="mt-3 text-[0.74rem] font-semibold uppercase tracking-[0.24em] text-[var(--c-accent)]">
          Tâhâ 20:114
        </figcaption>
      </figure>

      <div class="home-hero__cue flex justify-center">
        <ScrollCue href="#ilk-esik" labelTr={uiCopy.tr.goDeeper} labelEn={uiCopy.en.goDeeper} class="scroll-cue--hero" />
      </div>
    </div>
  </section>

  <section
    class="home-journey"
    aria-label="Derinleşen akış"
    data-locale-label-tr="Derinleşen akış"
    data-locale-label-en="Descending journey"
  >
    <article id="ilk-esik" class="journey-stage journey-stage--light">
      <div class="journey-shell">
        <LocalizedText as="p" class="journey-label" tr="İlk durak" en="First threshold" />
        <LocalizedText
          as="blockquote"
          class="journey-quote"
          tr="“Bu kitap, mutlak gerçeğin ta kendisidir.”"
          en="“This Book is the very truth itself.”"
        />
        <p class="journey-reference">Bakara 2:2</p>
        <LocalizedText
          as="h2"
          class="journey-title journey-title--subtle"
          tr="Metin önce kendini tanıtır."
          en="The text first introduces itself."
        />
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#ikinci-esik" />
        </div>
      </div>
    </article>

    <article id="ikinci-esik" class="journey-stage journey-stage--mid">
      <div class="journey-shell">
        <LocalizedText as="p" class="journey-label" tr="İkinci durak" en="Second threshold" />
        <LocalizedText
          as="blockquote"
          class="journey-quote"
          tr="“Eğer kulumuza indirdiğimizden yana şüphede iseniz, haydi onun benzeri bir sure getirin.”"
          en="“If you are in doubt about what We have sent down to Our servant, then bring a surah like it.”"
        />
        <p class="journey-reference">Bakara 2:23-24</p>
        <LocalizedText
          as="h2"
          class="journey-title journey-title--subtle"
          tr="Burada çağrı açılır."
          en="Here the challenge opens."
        />
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#ucuncu-esik" />
        </div>
      </div>
    </article>

    <article id="ucuncu-esik" class="journey-stage journey-stage--deep">
      <div class="journey-shell">
        <LocalizedText as="p" class="journey-label" tr="Şüphe konuşur" en="Doubt speaks" />
        <LocalizedText
          as="blockquote"
          class="journey-quote journey-quote--deep"
          tr="“Bu, insan sözünden başka bir şey değildir.”"
          en="“This is nothing but human speech.”"
        />
        <p class="journey-reference journey-reference--deep">Müddessir 74:24-25</p>
        <LocalizedText
          as="h2"
          class="journey-title journey-title--subtle"
          tr="Burada itiraz görünür olur."
          en="Here the objection becomes visible."
        />
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#dorduncu-esik" />
        </div>
      </div>
    </article>

    <article id="dorduncu-esik" class="journey-stage journey-stage--deeper">
      <div class="journey-shell">
        <LocalizedText as="p" class="journey-label" tr="Cevap gelir" en="The answer comes" />
        <LocalizedText
          as="blockquote"
          class="journey-quote journey-quote--deep"
          tr="“Onun üzerinde on dokuz vardır.”"
          en="“Over it are nineteen.”"
        />
        <p class="journey-reference journey-reference--deep">Müddessir 74:30-31</p>
        <LocalizedText
          as="h2"
          class="journey-title journey-title--subtle"
          tr="Buradan sonra örüntüler başlar."
          en="From here, patterns begin."
        />
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#kod-19" />
        </div>
      </div>
    </article>

    <article id="kod-19" class="journey-stage journey-stage--code">
      <div class="journey-shell journey-shell--wide descent-shell">
        <header class="descent-intro reveal-step" data-reveal>
          <LocalizedText as="p" class="journey-label" tr="19 ile ilk temas" en="First contact with 19" />
          <LocalizedText
            as="h2"
            class="journey-title journey-title--descent"
            tr="İlk işaretler görünür olur."
            en="The first signs come into view."
          />
        </header>

        <div class="descent-rail">
          <article class="descent-step reveal-step" data-reveal style="--step-depth: 0;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="İlk ayet" en="First verse" />
                <LocalizedText as="p" class="descent-panel__value" tr="19 harf" en="19 letters" />
                <LocalizedText as="h3" class="descent-panel__title" tr="Besmele" en="Basmala" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="Kur'an'ın ilk ayeti Besmele 19 harftir."
                  en="The Qur'an's opening verse, the Basmala, contains 19 letters."
                />
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 1;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="Bütün" en="Whole" />
                <LocalizedText as="p" class="descent-panel__value" tr="114 sure" en="114 surahs" />
                <LocalizedText as="h3" class="descent-panel__title" tr="Kur'an" en="The Qur'an" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="Kur'an 114 sureden oluşur. 114 = 19 x 6."
                  en="The Qur'an consists of 114 surahs. 114 = 19 x 6."
                />
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 2;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="İlk vahiy" en="First revelation" />
                <p class="descent-panel__value">96 / 19</p>
                <LocalizedText as="h3" class="descent-panel__title" tr="Alak suresi" en="Surah Al-Alaq" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="İlk vahyedilen 96. sure, sondan 19. suredir."
                  en="The first revealed surah is number 96, and it is the 19th from the end."
                />
              </div>
            </div>
          </article>
        </div>

        <div class="mt-12 flex justify-center">
          <ScrollCue href="#kod-19-derin" />
        </div>
      </div>
    </article>

    <article id="kod-19-derin" class="journey-stage journey-stage--code-layer">
      <div class="journey-shell journey-shell--wide descent-shell">
        <header class="descent-intro reveal-step" data-reveal>
          <LocalizedText as="p" class="journey-label" tr="19 derinleşir" en="19 deepens" />
          <LocalizedText
            as="h2"
            class="journey-title journey-title--descent"
            tr="Aşağı indikçe bağlar çoğalır."
            en="As you descend, the connections multiply."
          />
        </header>

        <div class="descent-rail">
          <article class="descent-step reveal-step" data-reveal style="--step-depth: 0;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-detail-open="kayip-besmele">
                  <LocalizedText as="p" class="descent-panel__eyebrow" tr="Eksik ve tamam" en="Missing and complete" />
                  <p class="descent-panel__value">27 + 30 = 57</p>
                  <LocalizedText as="h3" class="descent-panel__title" tr="Kayıp Besmele" en="Missing Basmala" />
                  <LocalizedText
                    as="p"
                    class="descent-panel__text"
                    tr="9. surenin başındaki eksik Besmele, 27. surenin 30. ayetindeki Besmele ile tamamlanır. 57 = 19 x 3."
                    en="The missing Basmala at the start of Surah 9 is completed by the Basmala in verse 30 of Surah 27. 57 = 19 x 3."
                  />
                  <LocalizedText as="span" class="descent-panel__cta" tr={uiCopy.tr.explore} en={uiCopy.en.explore} />
                </button>
              </article>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 1;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-detail-open="allah-kelimeler">
                  <LocalizedText as="p" class="descent-panel__eyebrow" tr="Tekrarlar" en="Repetitions" />
                  <p class="descent-panel__value">19 / 2698 / 57 / 114</p>
                  <LocalizedText as="h3" class="descent-panel__title" tr="Allah ve diğer kelimeler" en="Allah and the other words" />
                  <LocalizedText
                    as="p"
                    class="descent-panel__text"
                    tr="İsim = 19 x 1, Allah ve türevleri = 19 x 142, Rahman = 19 x 3, Rahim = 19 x 6. Ayet no'su 19'un katı olan ayetlerde 133 Allah kelimesi geçer."
                    en="Name = 19 x 1, Allah and its derivatives = 19 x 142, Al-Rahman = 19 x 3, Al-Rahim = 19 x 6. In verses whose verse number is a multiple of 19, the word Allah appears 133 times."
                  />
                  <LocalizedText as="span" class="descent-panel__cta" tr={uiCopy.tr.explore} en={uiCopy.en.explore} />
                </button>
              </article>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 2;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="Fatiha" en="Al-Fatiha" />
                <p class="descent-panel__value">1729 = 19 x 91</p>
                <LocalizedText as="h3" class="descent-panel__title" tr="İlk sure" en="First surah" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="Fatiha'daki ayet ve kelime dizilimi 1729 eder. 5. ayette 19 harf vardır: 19 = 19 x 1. Ebced değeri 836'dır: 836 = 19 x 44."
                  en="The verse and word sequence in Al-Fatiha gives 1729. Verse 5 contains 19 letters: 19 = 19 x 1. Its abjad value is 836: 836 = 19 x 44."
                />
              </div>
            </div>
          </article>
        </div>

        <div class="mt-12 flex justify-center">
          <ScrollCue href="#yedi-on-dokuz" />
        </div>
      </div>
    </article>

    <article id="yedi-on-dokuz" class="journey-stage journey-stage--method">
      <div class="journey-shell journey-shell--wide descent-shell">
        <header class="descent-intro reveal-step" data-reveal>
          <LocalizedText as="p" class="journey-label" tr="Daha derin bulgular" en="Deeper findings" />
          <LocalizedText
            as="h2"
            class="journey-title journey-title--descent"
            tr="Şimdi örnekler yoğunlaşır."
            en="Now the examples grow denser."
          />
        </header>

        <div class="descent-rail descent-rail--dense">
          <article class="descent-step reveal-step" data-reveal style="--step-depth: 0;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="İlk inen sure" en="First revealed surah" />
                <LocalizedText as="p" class="descent-panel__value" tr="285 harf" en="285 letters" />
                <LocalizedText as="h3" class="descent-panel__title" tr="19 ayet" en="19 verses" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="96. sure 19 ayettir. Bu 19 ayet 285 harf taşır ve 285 = 19 x 15'tir."
                  en="Surah 96 has 19 verses. Those 19 verses contain 285 letters, and 285 = 19 x 15."
                />
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 1;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="Tek ayet" en="Single verse" />
                <p class="descent-panel__value">57 : 19</p>
                <LocalizedText as="h3" class="descent-panel__title" tr="Aynı eşikte buluşur" en="They meet at one threshold" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="Kur'an ayet no'su 19'un katı, sure no'su 19'un katı ve ayet no'su 19'un katı olan tek ayet 57:19 ayetidir. Bu ayette 76 hurufu mukatta harfi kullanıldığı belirtilir."
                  en="The only verse whose Qur'anic verse number, surah number, and verse number are all multiples of 19 is 57:19. This verse is also said to contain 76 disconnected letters."
                />
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 2;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="Sondan 19." en="19th from the end" />
                <p class="descent-panel__value">82 : 19</p>
                <LocalizedText as="h3" class="descent-panel__title" tr="Son kelime" en="Final word" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="Kur'an'ın sondan 19. Allah kelimesi, 19 ayetli 82. surenin 19. ayetinin son kelimesidir. Bu, Kur'an'da ayetin son kelimesi olan tek Allah kelimesidir."
                  en="The 19th Allah from the end of the Qur'an is the last word of verse 19 in surah 82, which itself has 19 verses. It is the only Allah that appears as the final word of its verse."
                />
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 3;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <LocalizedText as="p" class="descent-panel__eyebrow" tr="Allah + kelime sayısı" en="Allah + word count" />
                <p class="descent-panel__value">18544 = 19 x 976</p>
                <LocalizedText as="h3" class="descent-panel__title" tr="Basamak sayısı" en="Digit count" />
                <LocalizedText
                  as="p"
                  class="descent-panel__text"
                  tr="Allah geçen ayetlerde, ayetteki Allah sayısı ile toplam kelime sayısı birlikte dizildiğinde 18544 basamaklı bir sayı oluşur. Burada 19'un katı olan şey bu büyük sayının basamak sayısıdır."
                  en="When the count of Allah within each verse is written together with the verse's total word count, a 18544-digit number is formed. What is a multiple of 19 here is the digit count of that number."
                />
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 4;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-fatiha-open>
                  <LocalizedText as="p" class="descent-panel__eyebrow" tr="Yakından bak" en="Look closer" />
                  <LocalizedText as="p" class="descent-panel__value" tr="Fatiha" en="Al-Fatiha" />
                  <LocalizedText as="h3" class="descent-panel__title" tr="Dizilimler" en="Sequences" />
                  <LocalizedText
                    as="p"
                    class="descent-panel__text"
                    tr="Ayet no, harf sayısı ve ebced değeri birlikte yazıldığında oluşan dizilimlerin her biri 19'un katıdır."
                    en="When verse number, letter count, and abjad value are written together, each resulting sequence is a multiple of 19."
                  />
                  <LocalizedText as="span" class="descent-panel__cta" tr={uiCopy.tr.explore} en={uiCopy.en.explore} />
                </button>
              </article>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 5;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-15124-open>
                  <LocalizedText as="p" class="descent-panel__eyebrow" tr="Yakından bak" en="Look closer" />
                  <LocalizedText as="p" class="descent-panel__value" tr="15124 basamak" en="15124 digits" />
                  <LocalizedText as="h3" class="descent-panel__title" tr="Allah dizilimi" en="Allah sequence" />
                  <LocalizedText
                    as="p"
                    class="descent-panel__text"
                    tr="Allah kelimesinin geçtiği ayetlerin sırası, sure numarası, ayet numarası ve ayetteki geçiş sayısı art arda dizildiğinde 15124 basamaklı bir sayı oluşur."
                    en="When the order of each verse containing Allah, the surah number, the verse number, and the occurrence count are written one after another, a 15124-digit number is formed."
                  />
                  <LocalizedText as="span" class="descent-panel__cta" tr={uiCopy.tr.explore} en={uiCopy.en.explore} />
                </button>
              </article>
            </div>
          </article>
        </div>

        <div class="descent-outro reveal-step" data-reveal>
          <p class="journey-note">
            <span data-copy-lang="tr">
              Devam için
              <a href="https://www.7ve19.com/0038-kodlama-denemelerini-nerede-yapabilirim/" target="_blank" rel="noreferrer">
                kodlama kuralları
              </a>
              ,
