---
import Layout from "../layouts/Layout.astro";
import ScrollCue from "../components/ScrollCue.astro";
import { allah15124Number } from "../data/allah15124";

const besmeleCriteriaGroups = [
  {
    id: "temel",
    range: "B1-B2",
    title: "Temel ölçüler",
    intro: "İlk bakışta görünen ana ölçüler burada toplanır.",
    items: [
      ["B1", "Harf sayısı", "19", "mod 19 = 0"],
      ["B2", "Kelime, harf ve ebced dizilimi", "4 19 786", "mod 19 = 0"]
    ]
  },
  {
    id: "harf",
    range: "B3-B4",
    title: "Harf dizilimleri",
    intro: "Kelime sırası ve harf düzeni birlikte okunur.",
    items: [
      ["B3", "Kelime sırası ve harf sayıları", "1 3 / 2 4 / 3 6 / 4 6 ve tersi", "iki yönde mod 19 = 0"],
      ["B4", "Kelime numarası ve kümülatif harf toplamları", "1 3 / 2 7 / 3 13 / 4 19", "mod 19 = 0"]
    ]
  },
  {
    id: "ebced",
    range: "B5-B6.1",
    title: "Ebced dizilimleri",
    intro: "Ebced değerleri tek tek ve kümülatif biçimde izlenir.",
    items: [
      ["B5", "Kelime sırası ve ebced değerleri", "1 102 / 2 66 / 3 329 / 4 289", "mod 19 = 0"],
      ["B6", "Kelime numarası ve kümülatif ebced toplamları", "1 102 / 2 168 / 3 497 / 4 786", "mod 19 = 0"],
      ["B6.1", "Asal çarpan toplamları dizilimi", "0 22 2 16 3 78 4 136", "mod 19 = 0"]
    ]
  },
  {
    id: "ileri",
    range: "B7-B9",
    title: "İleri ölçütler",
    intro: "Daha yoğun dizilimler ve birleşik yapılar bu katmanda yer alır.",
    items: [
      ["B7", "Kelime ve harf ebced dizilimi", "Düz, ters, basamak toplamı ve kayan pencere", "hepsi mod 19 = 0"],
      ["B8", "Harf ebcedlerinin kümülatif dizilimi", "1 2 62 102 ... 4 786", "mod 19 = 0"],
      ["B9", "Kelime sıra no, harf sıra no ve harf ebced dizilimi", "1 1 2 2 60 ... 4 1 30 200 8 10 40", "mod 19 = 0"]
    ]
  }
];

const escapeHtml = (value) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;");

const highlightNumericText = (value) =>
  escapeHtml(value).replace(/(\d+(?:\.\d+)?|mod|x|=)/g, '<span class="criteria-number">$1</span>');

const allah15124Preview = allah15124Number.match(/.{1,88}/g)?.join("\n") ?? allah15124Number;

const allah15124Fields = [
  ["Kuran ayet no", "number-field--quran-ayah"],
  ["Sure no", "number-field--surah"],
  ["Suredeki ayet no", "number-field--surah-ayah"],
  ["Geçiş sayısı", "number-field--count"]
];

const allah15124Sequence = [
  ["1", "1", "1", "1"],
  ["2", "1", "2", "1"],
  ["14", "2", "7", "1"],
  ["6221", "112", "2", "1"]
];

const allahWordBreakdown = [
  ["İsim", "19 = 19 x 1"],
  ["Allah ve türevleri", "2698 = 19 x 142"],
  ["Rahman", "57 = 19 x 3"],
  ["Rahim", "114 = 19 x 6"],
  ["Ayet no'su 19'un katı olan ayetlerde Allah", "133, 19'un katıdır."],
  ["Allah + er-Rahman + er-Rahim", "684 = 19 x 36"]
];
---

<Layout>
  <section class="home-hero">
    <div class="mx-auto max-w-4xl px-5 py-18 text-center md:px-8 md:py-28">
      <h1 class="mx-auto mt-6 max-w-4xl font-serif text-4xl leading-[1.08] text-balance text-[var(--c-ink)] md:text-7xl">
        Kur'an'ı anlamak.
      </h1>
      <figure class="mx-auto mt-7 max-w-xl">
        <blockquote class="font-serif text-xl leading-9 text-[var(--c-ink-soft)] md:text-2xl md:leading-10">
          “Rabbim, ilmimi artır.”
        </blockquote>
        <figcaption class="mt-3 text-[0.74rem] font-semibold uppercase tracking-[0.24em] text-[var(--c-accent)]">
          Tâhâ 20:114
        </figcaption>
      </figure>

      <div class="mt-18 flex justify-center md:mt-22">
        <ScrollCue href="#ilk-esik" label="Derine in" />
      </div>
    </div>
  </section>

  <section class="home-journey" aria-label="Derinleşen akış">
    <article id="ilk-esik" class="journey-stage journey-stage--light">
      <div class="journey-shell">
        <p class="journey-label">İlk durak</p>
        <blockquote class="journey-quote">
          “Bu kitap, mutlak gerçeğin ta kendisidir.”
        </blockquote>
        <p class="journey-reference">Bakara 2:2</p>
        <h2 class="journey-title journey-title--subtle">Metin önce kendini tanıtır.</h2>
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#ikinci-esik" label="Aşağı in" />
        </div>
      </div>
    </article>

    <article id="ikinci-esik" class="journey-stage journey-stage--mid">
      <div class="journey-shell">
        <p class="journey-label">İkinci durak</p>
        <blockquote class="journey-quote">
          “Eğer kulumuza indirdiğimizden yana şüphede iseniz, haydi onun benzeri bir sure getirin.”
        </blockquote>
        <p class="journey-reference">Bakara 2:23-24</p>
        <h2 class="journey-title journey-title--subtle">Burada çağrı açılır.</h2>
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#ucuncu-esik" label="Aşağı in" />
        </div>
      </div>
    </article>

    <article id="ucuncu-esik" class="journey-stage journey-stage--deep">
      <div class="journey-shell">
        <p class="journey-label">Şüphe konuşur</p>
        <blockquote class="journey-quote journey-quote--deep">
          “Bu, insan sözünden başka bir şey değildir.”
        </blockquote>
        <p class="journey-reference journey-reference--deep">Müddessir 74:24-25</p>
        <h2 class="journey-title journey-title--subtle">Burada itiraz görünür olur.</h2>
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#dorduncu-esik" label="Aşağı in" />
        </div>
      </div>
    </article>

    <article id="dorduncu-esik" class="journey-stage journey-stage--deeper">
      <div class="journey-shell">
        <p class="journey-label">Cevap gelir</p>
        <blockquote class="journey-quote journey-quote--deep">
          “Onun üzerinde on dokuz vardır.”
        </blockquote>
        <p class="journey-reference journey-reference--deep">Müddessir 74:30-31</p>
        <h2 class="journey-title journey-title--subtle">Buradan sonra örüntüler başlar.</h2>
        <div class="mt-10 flex justify-center">
          <ScrollCue href="#kod-19" label="Aşağı in" />
        </div>
      </div>
    </article>

    <article id="kod-19" class="journey-stage journey-stage--code">
      <div class="journey-shell journey-shell--wide descent-shell">
        <header class="descent-intro reveal-step" data-reveal>
          <p class="journey-label">19 ile ilk temas</p>
          <h2 class="journey-title journey-title--descent">İlk işaretler görünür olur.</h2>
        </header>

        <div class="descent-rail">
          <article class="descent-step reveal-step" data-reveal style="--step-depth: 0;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">İlk ayet</p>
                <p class="descent-panel__value">19 harf</p>
                <h3 class="descent-panel__title">Besmele</h3>
                <p class="descent-panel__text">Kur'an'ın ilk ayeti Besmele 19 harftir.</p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 1;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">Bütün</p>
                <p class="descent-panel__value">114 sure</p>
                <h3 class="descent-panel__title">Kur'an</h3>
                <p class="descent-panel__text">Kur'an 114 sureden oluşur. 114 = 19 x 6.</p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 2;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">İlk vahiy</p>
                <p class="descent-panel__value">96 / 19</p>
                <h3 class="descent-panel__title">Alak suresi</h3>
                <p class="descent-panel__text">İlk vahyedilen 96. sure, sondan 19. suredir.</p>
              </div>
            </div>
          </article>
        </div>

        <div class="mt-12 flex justify-center">
          <ScrollCue href="#kod-19-derin" label="Aşağı in" />
        </div>
      </div>
    </article>

    <article id="kod-19-derin" class="journey-stage journey-stage--code-layer">
      <div class="journey-shell journey-shell--wide descent-shell">
        <header class="descent-intro reveal-step" data-reveal>
          <p class="journey-label">19 derinleşir</p>
          <h2 class="journey-title journey-title--descent">Aşağı indikçe bağlar çoğalır.</h2>
        </header>

        <div class="descent-rail">
          <article class="descent-step reveal-step" data-reveal style="--step-depth: 0;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">Toplam</p>
                <p class="descent-panel__value">6346 ayet</p>
                <h3 class="descent-panel__title">Tam sayı</h3>
                <p class="descent-panel__text">Numarasız Besmeleler dahil toplam 6346 ayet vardır. 6346 = 19 x 334.</p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 1;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-detail-open="kayip-besmele">
                  <p class="descent-panel__eyebrow">Eksik ve tamam</p>
                  <p class="descent-panel__value">27 + 30 = 57</p>
                  <h3 class="descent-panel__title">Kayıp Besmele</h3>
                  <p class="descent-panel__text">
                    9. surenin başındaki eksik Besmele, 27. surenin 30. ayetindeki Besmele ile tamamlanır. 57 = 19 x 3.
                  </p>
                  <span class="descent-panel__cta">İncele</span>
                </button>
              </article>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 2;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-detail-open="allah-kelimeler">
                  <p class="descent-panel__eyebrow">Tekrarlar</p>
                  <p class="descent-panel__value">19 / 2698 / 57 / 114</p>
                  <h3 class="descent-panel__title">Allah ve diğer kelimeler</h3>
                  <p class="descent-panel__text">
                    İsim = 19 x 1, Allah ve türevleri = 19 x 142, Rahman = 19 x 3, Rahim = 19 x 6. Ayet no'su 19'un katı olan ayetlerde 133 Allah kelimesi geçer.
                  </p>
                  <span class="descent-panel__cta">İncele</span>
                </button>
              </article>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 3;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">Fatiha</p>
                <p class="descent-panel__value">1729 = 19 x 91</p>
                <h3 class="descent-panel__title">İlk sure</h3>
                <p class="descent-panel__text">
                  Fatiha'daki ayet ve kelime dizilimi 1729 eder. 5. ayette 19 harf vardır: 19 = 19 x 1. Ebced değeri 836'dır: 836 = 19 x 44.
                </p>
              </div>
            </div>
          </article>
        </div>

        <div class="mt-12 flex justify-center">
          <ScrollCue href="#yedi-on-dokuz" label="Aşağı in" />
        </div>
      </div>
    </article>

    <article id="yedi-on-dokuz" class="journey-stage journey-stage--method">
      <div class="journey-shell journey-shell--wide descent-shell">
        <header class="descent-intro reveal-step" data-reveal>
          <p class="journey-label">Daha derin bulgular</p>
          <h2 class="journey-title journey-title--descent">Şimdi örnekler yoğunlaşır.</h2>
        </header>

        <div class="descent-rail descent-rail--dense">
          <article class="descent-step reveal-step" data-reveal style="--step-depth: 0;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">İlk inen sure</p>
                <p class="descent-panel__value">285 harf</p>
                <h3 class="descent-panel__title">19 ayet</h3>
                <p class="descent-panel__text">
                  96. sure 19 ayettir. Bu 19 ayet 285 harf taşır ve 285 = 19 x 15'tir.
                </p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 1;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">Tek ayet</p>
                <p class="descent-panel__value">57 : 19</p>
                <h3 class="descent-panel__title">Aynı eşikte buluşur</h3>
                <p class="descent-panel__text">
                  Kur'an ayet no'su 19'un katı, sure no'su 19'un katı ve ayet no'su 19'un katı olan tek ayet 57:19 ayetidir. Bu ayette 76 hurufu mukatta harfi kullanıldığı belirtilir.
                </p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 2;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">Sondan 19.</p>
                <p class="descent-panel__value">82 : 19</p>
                <h3 class="descent-panel__title">Son kelime</h3>
                <p class="descent-panel__text">
                  Kur'an'ın sondan 19. Allah kelimesi, 19 ayetli 82. surenin 19. ayetinin son kelimesidir. Bu, Kur'an'da ayetin son kelimesi olan tek Allah kelimesidir.
                </p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 3;">
            <div class="descent-step__inner">
              <div class="descent-panel">
                <p class="descent-panel__eyebrow">Allah + kelime sayısı</p>
                <p class="descent-panel__value">18544 = 19 x 976</p>
                <h3 class="descent-panel__title">Basamak sayısı</h3>
                <p class="descent-panel__text">
                  Allah geçen ayetlerde, ayetteki Allah sayısı ile toplam kelime sayısı birlikte dizildiğinde 18544 basamaklı bir sayı oluşur. Burada 19'un katı olan şey bu büyük sayının basamak sayısıdır.
                </p>
              </div>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 4;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-fatiha-open>
                  <p class="descent-panel__eyebrow">Yakından bak</p>
                  <p class="descent-panel__value">Fatiha</p>
                  <h3 class="descent-panel__title">Dizilimler</h3>
                  <p class="descent-panel__text">
                    Ayet no, harf sayısı ve ebced değeri birlikte yazıldığında oluşan dizilimlerin her biri 19'un katıdır.
                  </p>
                  <span class="descent-panel__cta">İncele</span>
                </button>
              </article>
            </div>
          </article>

          <article class="descent-step reveal-step" data-reveal style="--step-depth: 5;">
            <div class="descent-step__inner">
              <article class="descent-panel descent-panel--trigger">
                <button type="button" class="descent-panel__button" data-15124-open>
                  <p class="descent-panel__eyebrow">Yakından bak</p>
                  <p class="descent-panel__value">15124 basamak</p>
                  <h3 class="descent-panel__title">Allah dizilimi</h3>
                  <p class="descent-panel__text">
                    Allah kelimesinin geçtiği ayetlerin sırası, sure numarası, ayet numarası ve ayetteki geçiş sayısı art arda dizildiğinde 15124 basamaklı bir sayı oluşur.
                  </p>
                  <span class="descent-panel__cta">İncele</span>
                </button>
              </article>
            </div>
          </article>
        </div>

        <div class="descent-outro reveal-step" data-reveal>
          <p class="journey-note">
            Devam için
            <a href="https://www.7ve19.com/0038-kodlama-denemelerini-nerede-yapabilirim/" target="_blank" rel="noreferrer">
              kodlama kuralları
            </a>
            ,
            <a href="https://www.7ve19.com/0045-kuran-yazisinda-insanin-yapamayacagi-sey-nedir-nasil-gorebiliriz/" target="_blank" rel="noreferrer">
              insanın yapamayacağı şey
            </a>
            ,
            <a href="https://kuranmucizeler.com/kuran-ayet-no-su-19-un-kati-sure-no-su-19-un-kati-ve-ayet-no-su-19-un-kati-olan-tek-ayet-57-19-ayetidir-bu-ayette-yuce-allah-76-19x-hurufu-mukatta-harfi-kullanmistir" target="_blank" rel="noreferrer">
              57:19 bulgusu
            </a>
            ,
            <a href="https://kuranmucizeler.com/kuran-in-sondan-19-allah-kelimesi-19-ayetli-82-surenin-19-ayetinin-son-kelimesidir-bu-allah-kelimesi-tum-kuran-da-icinde-bulundugu-ayetin-son-kelimesi-olan-biricik-allah-kelimesidir" target="_blank" rel="noreferrer">
              sondan 19. Allah
            </a>
            ,
            <a href="https://kuranmucizeler.com/kuran-da-ayet-numarasi-19-un-kati-olan-ayetlerde-toplam-133-allah-kelimesi-gecer-ki-bu-rakam-19-un-tam-katidir" target="_blank" rel="noreferrer">
              133 Allah
            </a>
            ve
            <a href="https://kuranmucizeler.com/ayetteki-allah-kelimesi-sayisi-ve-ayetteki-toplam-kelime-sayisinin-isareti-18544-19x-basamakli-sayi" target="_blank" rel="noreferrer">
              18544 basamaklı sayı
            </a>
            ,
            <a href="https://kuranmucizeler.com/fatiha-daki-muhtesem-mucize-19-sistemi" target="_blank" rel="noreferrer">
              Fatiha'daki 19 kodlaması
            </a>
            .
          </p>

          <p class="journey-note journey-note--question">
            Soru artık şudur: Bu kadar çok uyum, gerçekten tesadüf ile açıklanabilir mi?
          </p>
        </div>

        <dialog class="number-dialog" data-15124-dialog>
          <div class="number-dialog__panel">
            <div class="number-dialog__top">
              <div>
                <p class="journey-label">15124 basamaklı sayı</p>
              </div>
              <button type="button" class="number-dialog__close" data-15124-close>Kapat</button>
            </div>

            <p class="signal-card__text number-dialog__text">
              Allah ve türevleri <span class="signal-inline-number">1820</span> ayette
              <span class="signal-inline-number">2698</span> kez geçer. Her geçiş için şu dört bilgi
              yan yana yazılır:
            </p>

            <div class="number-build">
              {
                allah15124Fields.map(([label, className]) => (
                  <div class={`number-build__step ${className}`}>
                    <span>{label}</span>
                  </div>
                ))
              }
            </div>

            <p class="number-dialog__sequence">
              {
                allah15124Sequence.map(([quranAyah, surahNo, surahAyah, count], index) => (
                  <>
                    <span class="signal-inline-group">
                      <span class="signal-inline-token number-field--quran-ayah">{quranAyah}</span>
                      <span class="signal-inline-separator">|</span>
                      <span class="signal-inline-token number-field--surah">{surahNo}</span>
                      <span class="signal-inline-separator">|</span>
                      <span class="signal-inline-token number-field--surah-ayah">{surahAyah}</span>
                      <span class="signal-inline-separator">|</span>
                      <span class="signal-inline-token number-field--count">{count}</span>
                    </span>
                    {index === 2 && <span class="signal-inline-number">...</span>}
                  </>
                ))
              }
            </p>

            <label class="number-analyzer">
              <span class="number-analyzer__label">Sayı</span>
              <textarea class="number-analyzer__input number-analyzer__input--editor" data-15124-input>{allah15124Preview}</textarea>
            </label>

            <div class="number-analyzer__actions">
              <button type="button" class="number-analyzer__button" data-15124-analyze>Analiz et</button>
              <button type="button" class="number-analyzer__button number-analyzer__button--ghost" data-15124-mutate>
                Bir rakam değiştir
              </button>
              <button type="button" class="number-analyzer__button number-analyzer__button--ghost" data-15124-reset>
                Geri al
              </button>
            </div>

            <p class="number-analyzer__status" data-15124-status>
              15124 basamaklı sayı hazır.
            </p>
          </div>
        </dialog>

        <dialog class="number-dialog" data-fatiha-dialog>
          <div class="number-dialog__panel">
            <div class="number-dialog__top">
              <div>
                <p class="journey-label">Fatiha tam dizilim</p>
              </div>
              <button type="button" class="number-dialog__close" data-fatiha-close>Kapat</button>
            </div>

            <p class="signal-card__text number-dialog__text">
              Fatiha için verilen 19 dizilimleri aşağıdaki gibi özetlenir:
            </p>

            <div class="pattern-list">
              <article class="pattern-item">
                <h3>Ayet numaraları</h3>
                <p>1 1 2 3 4 5 6 7 = 19x</p>
              </article>

              <article class="pattern-item">
                <h3>Harf sayıları</h3>
                <p>1 19 17 12 11 19 18 43 = 19x</p>
              </article>

              <article class="pattern-item">
                <h3>Harf ve ebced</h3>
                <p>1 19 786 17 581 12 618 11 241 19 836 18 1072 43 6009 = 19x</p>
              </article>

              <article class="pattern-item">
                <h3>Tam dizilim</h3>
                <p>1 1 19 786 2 17 581 3 12 618 4 11 241 5 19 836 6 18 1072 7 43 6009 = 19x</p>
              </article>

              <article class="pattern-item">
